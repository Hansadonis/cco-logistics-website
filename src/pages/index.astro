<div id="form-success" class="hidden bg-green-100 border-l-4 border-green-500 text-green-700 p-8 rounded-xl shadow-lg mt-6" role="alert" aria-live="polite">
    <h3 class="text-2xl font-bold mb-2">Thank you!</h3>
