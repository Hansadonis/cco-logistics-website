				<form id="quote-form" action="https://formspree.io/f/meenydlg" method="POST" class="bg-white p-8 rounded-xl shadow-2xl space-y-6 text-slate-800" novalidate>
	<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
		<div>
			<label for="form-name" class="block text-sm font-bold text-slate-700 mb-2">Full Name <span class="text-red-600" aria-label="required">*</span></label>
			<input 
				type="text" 
				id="form-name"
				name="name" 
				required 
				class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" 
				placeholder="John Doe"
				aria-required="true">
		</div>
		<div>
			<label for="form-phone" class="block text-sm font-bold text-slate-700 mb-2">Phone Number <span class="text-red-600" aria-label="required">*</span></label>
			<input 
				type="tel" 
				id="form-phone"
				name="phone" 
				required 
				class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" 
				placeholder="(555) 000-0000"
				aria-required="true">
		</div>
	</div>
	<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
		<div>
			<label for="form-zip-from" class="block text-sm font-bold text-slate-700 mb-2">Moving From (Address) <span class="text-red-600" aria-label="required">*</span></label>
			<input 
				type="text" 
				id="form-zip-from"
				name="address_from" 
				required 
				class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" 
				placeholder="e.g. 123 Main St, Baltimore, MD"
				aria-required="true">
		</div>
		<div>
			<label for="form-zip-to" class="block text-sm font-bold text-slate-700 mb-2">Moving To (Address) <span class="text-red-600" aria-label="required">*</span></label>
			<input 
				type="text" 
				id="form-zip-to"
				name="address_to" 
				required 
				class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" 
				placeholder="e.g. 456 Oak Ave, Annapolis, MD"
				aria-required="true">
		</div>
	</div>
	<div>
		<label for="form-details" class="block text-sm font-bold text-slate-700 mb-2">Move Date & Details <span class="text-red-600" aria-label="required">*</span></label>
		<textarea 
			id="form-details"
			name="details" 
			required 
			rows="4" 
			class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition" 
			placeholder="Tell us about the size of your move (e.g., 2-bedroom apartment)..."
			aria-required="true"></textarea>
	</div>
	<button 
		type="submit" 
		class="w-full bg-green-500 hover:bg-green-600 text-slate-900 font-extrabold py-4 px-8 rounded-lg shadow-lg transition text-lg focus:outline-none focus:ring-2 focus:ring-green-700"
		aria-label="Submit quote request">
		Submit Request
	</button>
</form>

